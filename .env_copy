# Template only — copy to .env and replace placeholders with your real values.
# Do not commit .env (it contains secrets).

MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.example.mongodb.net/real_interview
MONGODB_DB_NAME=real_interview
MONGODB_COLLECTION_USERS=authentications
MONGODB_COLLECTION_RESUMES=resumes
MONGODB_COLLECTION_JOB_APPLICATIONS=job_application
MONGODB_COLLECTION_INTERVIEW=interview
MONGODB_COLLECTION_QUESTION_BANK=interview_question_bank
MONGODB_COLLECTION_RATE_LIMITS=rate_limits
MONGODB_COLLECTION_REVOKED_TOKENS=revoked_tokens
MONGODB_GRIDFS_RESUME_BUCKET=resume_pdf_fs
MONGODB_CHECKPOINT_COLLECTION=checkpoints
MONGODB_CHECKPOINT_WRITES_COLLECTION=checkpoint_writes

OPENAI_API_KEY=sk-proj-your-key
TAVILY_API_KEY=tvly-your-key

# Local dev only — generate yourself (32+ random characters):
#   python -c "import secrets; print(secrets.token_hex(32))"
# On Render, render.yaml uses generateValue: true so you do NOT set this manually there.
JWT_SECRET_KEY=your-generated-secret-here
JWT_EXPIRE_HOURS=24

PORT=5000
HOST=0.0.0.0

# Production (HTTPS) — required on public hosts
# COOKIE_SECURE=true

# Optional Gunicorn tuning (production)
# WEB_CONCURRENCY=2
# GUNICORN_THREADS=4
# GUNICORN_TIMEOUT=120
